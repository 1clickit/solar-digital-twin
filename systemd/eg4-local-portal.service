[Unit]
Description=Solar Digital Twin EG4 local portal
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=chris
Group=chris
ExecStart=/usr/bin/python3 -m http.server 8000 --directory /home/chris/solar-digital-twin/reports --bind 0.0.0.0
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
